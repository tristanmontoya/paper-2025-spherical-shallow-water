      <Property name="Input" id="17620.Input" number_of_elements="1">
        <Proxy value="17356" output_port="0"/>
        <Domain name="groups" id="17620.Input.groups"/>
        <Domain name="input_type" id="17620.Input.input_type"/>
      </Property>
      <Property name="OutputDataSetType" id="17620.OutputDataSetType" number_of_elements="1">
        <Element index="0" value="8"/>
        <Domain name="enum" id="17620.OutputDataSetType.enum">
          <Entry value="8" text="Same as Input"/>
          <Entry value="0" text="vtkPolyData"/>
          <Entry value="2" text="vtkStructuredGrid"/>
          <Entry value="3" text="vtkRectilinearGrid"/>
          <Entry value="4" text="vtkUnstructuredGrid"/>
          <Entry value="6" text="vtkImageData"/>
          <Entry value="10" text="vtkUniformGrid"/>
          <Entry value="13" text="vtkMultiblockDataSet"/>
          <Entry value="15" text="vtkHierarchicalBoxDataSet"/>
          <Entry value="32" text="vtkHyperTreeGrid"/>
          <Entry value="19" text="vtkTable"/>
          <Entry value="33" text="vtkMolecule"/>
          <Entry value="37" text="vtkPartitionedDataSet"/>
          <Entry value="38" text="vtkPartitionedDataSetCollection"/>
        </Domain>
      </Property>
      <Property name="PythonPath" id="17620.PythonPath" number_of_elements="1">
        <Element index="0" value=""/>
      </Property>
      <Property name="Script" id="17620.Script" number_of_elements="1">
        <Element index="0" value="# 1) Imports&#xa;from paraview.vtk.numpy_interface import dataset_adapter as dsa&#xa;from vtk.util.numpy_support import vtk_to_numpy, numpy_to_vtk&#xa;import vtk&#xa;import numpy as np&#xa;&#xa;# 2) Grab input and output&#xa;#    &#x27;inputs[0]&#x27; is already a VTK-wrapped object in ParaView’s Programmable Filter&#xa;inp = inputs[0]                  # VTKObjectWrapper&#xa;src = inp.VTKObject              # the raw vtkUnstructuredGrid&#xa;out = self.GetOutputDataObject(0)&#xa;&#xa;# 3) Convert VTK points to NumPy&#xa;pts_vtk = src.GetPoints().GetData()&#xa;pts = vtk_to_numpy(pts_vtk)      # shape (N,3) NumPy array :contentReference[oaicite:1]{index=1}&#xa;x, y, z = pts[:,0], pts[:,1], pts[:,2]&#xa;&#xa;# 4) Compute lon/lat&#xa;r   = np.sqrt(x*x + y*y + z*z)&#xa;lon = np.degrees(np.arctan2(y, x))  # range −180…+180&#xa;lat = np.degrees(np.arcsin(np.clip(z/r, -1.0, 1.0)))  # clip for safety&#xa;&#xa;# 5) Build new 2D points array&#xa;new_pts = np.column_stack((lon, lat, np.zeros_like(lon)))&#xa;&#xa;# 6) Convert back to vtkPoints&#xa;vtk_pts = vtk.vtkPoints()&#xa;vtk_pts.SetData(numpy_to_vtk(new_pts, deep=True))&#xa;&#xa;# 7) Copy everything from input to output, then replace points&#xa;out.DeepCopy(src)&#xa;out.SetPoints(vtk_pts)&#xa;"/>
      </Property>
      <Property name="TimestepValues" id="17620.TimestepValues"/>
      <Property name="UpdateExtentScript" id="17620.UpdateExtentScript" number_of_elements="1">
        <Element index="0" value=""/>
      </Property>
    </Proxy>
